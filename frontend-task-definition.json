{
    "family": "ep3-frontend-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::034922281063:role/LabRole",
    "containerDefinitions": [
        {
            "name": "frontend",
            "image": "034922281063.dkr.ecr.us-east-1.amazonaws.com/ep3-frontend:latest",
            "portMappings": [
                {
                    "containerPort": 80,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "VITE_API_URL",
                    "value": "http://ep3-alb-809675478.us-east-1.elb.amazonaws.com/api"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/ep3-frontend",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ]
}
